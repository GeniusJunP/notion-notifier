# タイムゾーン
timezone: "Asia/Tokyo"

# 基本設定
sync:
  check_interval: 15 # データ同期間隔（分）

# 事前通知（複数設定可）
notifications:
  advance:
    - enabled: true
      minutes_before: 30
      message: |
        @everyone **{{.Name}}** が **{{.MinutesBefore}}分後** に始まります！
        詳細は前のメッセージを参照してください。
      conditions:
        days_of_week: [] # 空配列=曜日制限なし
        property_filters: []

  # 定期通知（複数設定可）
  periodic:
    - enabled: true
      days_of_week: []
      time: "09:00"
      days_ahead: 7
      message: |
        {{if .Events}}
        ## 📣 今週の予定
        @everyone **今週は {{len .Events}} 件** あります！

        {{range .Events}}
        ### {{.Name}}
        {{with .Date}}- **日時:** {{.}} {{end}}{{if .IsAllDay}}終日{{else}}{{with .Time}} {{.}} {{end}}{{end}}{{with .EndDate}} 〜 {{.}}{{end}}{{with .EndTime}} {{.}}{{end}}
        {{with .Location}}- **場所:** {{.}}{{end}}
        {{with .URL}}- **詳細:** {{.}}{{end}}
        {{with .Content}}- **メモ:**
        {{.}}{{end}}

        {{end}}
        {{else}}
        @everyone 今週の予定はありません！
        {{end}}

# Webhook設定（任意JSON）
webhook:
  is_test: false
  notification:
    content_type: "application/json"
    payload_template: "{\"content\":{{json .Message}}}"
  internal_notification:
    content_type: "application/json"
    payload_template: "{\"content\":{{json .Message}}}"

# Google Calendar連携
calendar_sync:
  enabled: false
  interval_hours: 6
  lookahead_days: 30

# Notionプロパティマッピング
property_mapping:
  title: "名前"
  date: "日付"
  location: "場所"
  attendees: "" # Notionのpeopleプロパティ名（Calendar招待メール抽出用）
  attendees_enabled: false # attendees同期を有効にする
  custom: [] # カスタムマッピング（空配列=未設定）

# コンテンツ抽出ルール
content_rules:
  start_heading: "活動内容"
  include_start_heading: false
  stop_at_next_heading: true
  stop_at_delimiter: true
  delimiter_text: "---"

# 通知抑制
snooze_until: "" # ISO8601日時、空白=無効
